# INEI Estadist API MCP — optional configuration
# The API is fully public (no auth required)

INEI_CACHE_TTL=600       # Response cache in seconds (0 = disabled). Default: 10 min
INEI_TIMEOUT=30          # HTTP timeout in seconds. Default: 30
INEI_MAX_RETRIES=2       # Retries on transient errors. Default: 2
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
